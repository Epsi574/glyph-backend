# =============================================================
# VARIABLES D'ENVIRONNEMENT — Copie ce fichier en ".env"
# =============================================================
# Commande : cp .env.example .env
# Puis remplis chaque valeur.
# =============================================================

# ── PostgreSQL ──
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@HÔTE:PORT/NOM_BDD
#
# Option A — PostgreSQL local :
#   DATABASE_URL="postgresql://postgres:monmotdepasse@localhost:5432/jeu_de_mots"
#
# Option B — Supabase (gratuit, cloud) :
#   Va sur https://supabase.com → New Project → Settings → Database
#   Copie le "Connection string (URI)" et remplace [YOUR-PASSWORD]
#
DATABASE_URL="postgresql://postgres:monmotdepasse@localhost:5432/jeu_de_mots"

# ── Supabase Auth (pour plus tard, Phase 1) ──
# Va sur https://supabase.com → ton projet → Settings → API
#
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_ANON_KEY="eyJhbG..."

# ── Serveur ──
PORT=3001
